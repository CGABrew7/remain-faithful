#!/usr/bin/env bash
# Pre-commit hook: block files that contain patterns matching real secrets.
# Covers common key formats for Stripe, Anthropic, SendGrid, AWS, GitHub,
# generic JWT secrets, and PEM private keys.
#
# To install (one-time, per clone):
#   git config core.hooksPath .githooks

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Patterns that strongly indicate a real secret value.
# Each entry is a grep -E extended-regex.
SECRET_PATTERNS=(
  # Stripe
  'sk_(test|live)_[A-Za-z0-9]{24,}'
  'rk_(test|live)_[A-Za-z0-9]{24,}'
  'whsec_[A-Za-z0-9+/]{32,}'
  # Anthropic / Claude
  'sk-ant-[A-Za-z0-9\-_]{20,}'
  # SendGrid
  'SG\.[A-Za-z0-9_-]{22,}\.[A-Za-z0-9_-]{43,}'
  # AWS
  'AKIA[0-9A-Z]{16}'
  # GitHub tokens
  'gh[pousr]_[A-Za-z0-9]{36,}'
  'github_pat_[A-Za-z0-9_]{82,}'
  # Fly.io deploy tokens
  'fm2_[A-Za-z0-9+/=]{40,}'
  # Generic high-entropy assignments (e.g. JWT_SECRET=<64-char hex>)
  '(SECRET|TOKEN|PASSWORD|API_KEY|PRIVATE_KEY)\s*[:=]\s*["'"'"']?[A-Za-z0-9+/\-_]{32,}["'"'"']?'
  # PEM private keys
  '-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----'
)

STAGED=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$STAGED" ] && exit 0

FOUND=0

for file in $STAGED; do
  # Skip binary files and the hook itself
  [[ "$file" == ".githooks/"* ]] && continue
  git show ":$file" 2>/dev/null | file - | grep -q "binary" && continue

  for pattern in "${SECRET_PATTERNS[@]}"; do
    match=$(git show ":$file" 2>/dev/null | grep -En "$pattern" | head -3 || true)
    if [ -n "$match" ]; then
      echo -e "${RED}[secret-scan] Possible secret in staged file: $file${NC}"
      echo -e "${YELLOW}  Pattern : $pattern${NC}"
      echo "$match" | while IFS= read -r line; do
        echo "  Line    : $line"
      done
      echo ""
      FOUND=1
    fi
  done
done

if [ "$FOUND" -ne 0 ]; then
  echo -e "${RED}Commit blocked.${NC} Remove or redact the values above."
  echo "If this is a false positive, bypass with:  git commit --no-verify"
  exit 1
fi

exit 0
